{
  "mechanismVersion": "2.7.0",
  "whatsapp": {
    "mode": "auto_routing",
    "rules": {
      "wahaOnly": "Hanya WAHA_BASE_URL terisi → WAHA saja",
      "fonnteOnly": "Hanya FONNTE_TOKEN terisi → Fonnte saja",
      "both": "Keduanya terisi → WAHA primary, Fonnte backup",
      "forced": "WHATSAPP_PROVIDER=waha|fonnte → paksa single provider"
    },
    "allowedProviders": ["auto", "waha", "fonnte"],
    "propertyKeys": [
      "WHATSAPP_ENABLED",
      "WHATSAPP_PROVIDER",
      "WAHA_BASE_URL",
      "WAHA_API_KEY",
      "WAHA_SESSION",
      "FONNTE_TOKEN"
    ]
  },
  "waha": {
    "setupNote": "Jalankan setupWahaProperties(baseUrl, apiKey, session) sekali di setiap project Apps Script",
    "propertyKeys": [
      "WAHA_BASE_URL",
      "WAHA_API_KEY",
      "WAHA_SESSION"
    ],
    "defaultSession": "default",
    "sendEndpoint": "/api/sendText"
  },
  "fonnte": {
    "sendEndpoint": "https://api.fonnte.com/send"
  },
  "forms": {
